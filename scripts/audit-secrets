#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "${BASH_SOURCE[0]}")/.."

if rg --hidden --line-number --no-heading \
  --glob '!/.git/**' \
  --glob '!*.age' \
  --glob '!*.agekey' \
  --glob '!scripts/audit-secrets' \
  '([A-Za-z0-9_]*(TOKEN|SECRET|PASSWORD|PRIVATE_KEY|ACCESS_KEY)[A-Za-z0-9_]*=|-----BEGIN (OPENSSH|RSA|EC|DSA|PRIVATE) KEY-----)' \
  .; then
  echo "possible secret material found" >&2
  exit 1
fi

exit 0
